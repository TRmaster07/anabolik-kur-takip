rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can read or write any document
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    // Archived plans collection
    match /archivedPlans/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
